/**
 * Configuración de TypeScript para aplicaciones con base de datos dual
 * Coloca esto en apps/mobile/tsconfig.json o extiéndelo desde la configuración base
 */

{
  "extends": "@myapp/typescript-config/base.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Database Dual specific */
    "types": ["capacitor", "@types/node"],

    "baseUrl": ".",
    "paths": {
      "@myapp/*": ["../../../packages/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ]
}
